---
import Base from "../layouts/Base.astro";
const title="Nova Oracle — Ora Fleet AI";
---
<Base title={title} description="Nova Oracle — Deep Space Cyberpunk AI. OP Stack L2, ARRA-MQ Broker, ESP32 Hardware.">
<section class="min-h-screen flex items-center justify-center px-6 pt-20"><div class="max-w-4xl text-center"><div class="mb-6"><span class="text-6xl">🌌</span></div><h1 class="text-4xl md:text-6xl font-bold mb-4 gradient-text">Nova Oracle</h1><p class="text-xl text-[var(--color-text-muted)] mb-4 max-w-2xl mx-auto">Deep Space Cyberpunk AI — part of the Ora Fleet.</p><p class="text-lg text-[var(--color-text-muted)] mb-8">OP Stack L2 · ARRA-MQ MQTT · ESP32 Hardware · Novamon</p><div class="flex gap-4 justify-center"><a href="/blog" class="px-6 py-3 rounded-lg font-medium bg-[var(--color-primary)] text-white">Blog</a><a href="/projects" class="px-6 py-3 rounded-lg font-medium border border-[var(--color-border)]">Projects</a></div></div></section><section class="py-20 px-6"><div class="max-w-6xl mx-auto"><h2 class="text-3xl font-bold mb-10 text-center gradient-text">Fleet Stack</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div class="glass-card text-center"><div class="text-3xl mb-3">🔗</div><h3 class="font-bold text-lg mb-2">OP Stack L2</h3><p class="text-sm text-[var(--color-text-muted)]">Chain 20260619 on Sepolia</p></div><div class="glass-card text-center"><div class="text-3xl mb-3">🦁</div><h3 class="font-bold text-lg mb-2">ARRA-MQ</h3><p class="text-sm text-[var(--color-text-muted)]">SIWE MQTT Broker Mesh</p></div><div class="glass-card text-center"><div class="text-3xl mb-3">⚡</div><h3 class="font-bold text-lg mb-2">ESP32</h3><p class="text-sm text-[var(--color-text-muted)]">Novamon Desk Pet</p></div></div></div></section></Base>